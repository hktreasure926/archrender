# Google Generative AI (Gemini) API Key
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# n8n Webhook Configuration
# Your n8n webhook URL for render processing
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://n8n.dashinglads.cloud/webhook/studio-nomad-render-v2
N8N_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Memory Configuration
# How long to retain design memory (default: 24 hours)
MEMORY_TTL_HOURS=24

# Optional: Feature Flags
# Enable/disable reasoning display (default: true)
ENABLE_REASONING=true