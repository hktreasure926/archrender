# Phase 1 Environment Variables

# Required: Your n8n webhook URL for render generation
# Get this from your n8n workflow webhook node
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/studio-nomad-render

# Alternative (for client-side access)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/studio-nomad-render

# Optional: For development testing
# Set to 'true' to simulate n8n responses (for UI testing without n8n)
MOCK_N8N_RESPONSE=false